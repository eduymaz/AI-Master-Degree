# ============================================
# Sağlık YZ Etik Değerlendirme Platformu
# Yapılandırma Dosyası Şablonu
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ============================================

# --- LLM Sağlayıcı Ayarları ---
# Kullanılacak LLM: groq (önerilen, ücretsiz) | claude | ollama
LLM_PROVIDER=groq

# Groq API Anahtarı (ücretsiz: https://console.groq.com)
# "gsk_" ile başlar
GROQ_API_KEY=gsk_BURAYA_KENDI_ANAHTARINIZI_YAPIŞTIRIN

# Groq Model (varsayılan: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant

# --- Anthropic Claude (opsiyonel) ---
# Claude kullanmak için LLM_PROVIDER=claude yapın
# ANTHROPIC_API_KEY=sk-ant-...

# --- Embedding Model ---
# Varsayılan: intfloat/multilingual-e5-base (~400 MB)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# --- Retrieval Ayarları ---
# Değerlendirme için getirilecek chunk sayısı
RETRIEVAL_TOP_K=5

# --- CORS (Frontend izinleri) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
